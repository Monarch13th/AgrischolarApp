<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AgriScholarApp.Pages.SettingsPage"
             BackgroundColor="#F6F7FB">

    <Grid ColumnDefinitions="260,*" RowDefinitions="*">

        <!-- Sidebar -->
        <Grid Grid.Column="0" BackgroundColor="#0B1220">
            <Grid RowDefinitions="Auto,*" Padding="18,18,18,18" RowSpacing="18">

                <VerticalStackLayout Spacing="12">
                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Image Grid.RowSpan="2" Source="agrischolar.png" HeightRequest="34" WidthRequest="34" Aspect="AspectFit" />
                        <Label Grid.Column="1" Text="Agrischolars Admin Portal" TextColor="White" FontAttributes="Bold" FontSize="14" />
                        <Label Grid.Row="1" Grid.Column="1" Text="Management Dashboard" TextColor="#9AA4B2" FontSize="12" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="White" Opacity="0.45" HorizontalOptions="Fill" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Row="1" Spacing="10">
                    <HorizontalStackLayout Spacing="10" Margin="2,6,0,8" VerticalOptions="Center">
                        <Image Source="admin.png" HeightRequest="18" WidthRequest="18" />
                        <Label Text="Admin Panel" TextColor="White" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <Frame BackgroundColor="Transparent" CornerRadius="12" HasShadow="False" Padding="12,12">
                        <Grid ColumnDefinitions="24,*" ColumnSpacing="12">
                            <Image Source="icon_1.png" HeightRequest="18" WidthRequest="18" Opacity="0.85" />
                            <Label Grid.Column="1" Text="Dashboard" TextColor="#D5D9E0" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                        </Grid>
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDashboardClicked" />
                        </Frame.GestureRecognizers>
                    </Frame>

                    <Frame BackgroundColor="Transparent" CornerRadius="12" HasShadow="False" Padding="12,12">
                        <Grid ColumnDefinitions="24,*" ColumnSpacing="12">
                            <Image Source="icon_2.png" HeightRequest="18" WidthRequest="18" Opacity="0.85" />
                            <Label Grid.Column="1" Text="Scholars Management" TextColor="#D5D9E0" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                        </Grid>
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnScholarsManagementClicked" />
                        </Frame.GestureRecognizers>
                    </Frame>

                    <Frame BackgroundColor="Transparent" CornerRadius="12" HasShadow="False" Padding="12,12">
                        <Grid ColumnDefinitions="24,*" ColumnSpacing="12">
                            <Image Source="icon_3.png" HeightRequest="18" WidthRequest="18" Opacity="0.85" />
                            <Label Grid.Column="1" Text="Document Verification" TextColor="#D5D9E0" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                        </Grid>
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDocumentVerificationClicked" />
                        </Frame.GestureRecognizers>
                    </Frame>

                    <Frame BackgroundColor="Transparent" CornerRadius="12" HasShadow="False" Padding="12,12">
                        <Grid ColumnDefinitions="24,*" ColumnSpacing="12">
                            <Image Source="requirement.png" HeightRequest="18" WidthRequest="18" Opacity="0.85" />
                            <Label Grid.Column="1" Text="Requirements &amp; Announcements" TextColor="#D5D9E0" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                        </Grid>
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnRequirementsAnnouncementsClicked" />
                        </Frame.GestureRecognizers>
                    </Frame>

                    <Frame BackgroundColor="Transparent" CornerRadius="12" HasShadow="False" Padding="12,12">
                        <Grid ColumnDefinitions="24,*" ColumnSpacing="12">
                            <Image Source="icon_5.png" HeightRequest="18" WidthRequest="18" Opacity="0.85" />
                            <Label Grid.Column="1" Text="Reports &amp; Analytics" TextColor="#D5D9E0" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                        </Grid>
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnReportsAnalyticsClicked" />
                        </Frame.GestureRecognizers>
                    </Frame>

                    <!-- Active -->
                    <Frame BackgroundColor="#1E293B" CornerRadius="12" HasShadow="False" Padding="12,12">
                        <Grid ColumnDefinitions="24,*" ColumnSpacing="12">
                            <Image Source="icon_6.png" HeightRequest="18" WidthRequest="18" />
                            <Label Grid.Column="1" Text="Settings" TextColor="White" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                        </Grid>
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSettingsClicked" />
                        </Frame.GestureRecognizers>
                    </Frame>

                </VerticalStackLayout>
            </Grid>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*" BackgroundColor="#F6F7FB">

            <!-- Top Bar -->
            <Grid Grid.Row="0" BackgroundColor="#0B1220" Padding="22,14" ColumnDefinitions="*,Auto" HeightRequest="64">
                <HorizontalStackLayout Grid.Column="1" Spacing="14" VerticalOptions="Center">
                    <Grid HeightRequest="28" WidthRequest="28">
                        <Frame HeightRequest="28" WidthRequest="28" CornerRadius="14" BackgroundColor="#122038" HasShadow="False" Padding="0">
                            <Image Source="notification.png" HeightRequest="14" WidthRequest="14" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Frame>
                        <Frame x:Name="HeaderBadgeFrame" HeightRequest="16" MinimumWidthRequest="16" CornerRadius="8" BackgroundColor="#E11D48" HasShadow="False" Padding="0" HorizontalOptions="End" VerticalOptions="Start" Margin="0,-6,-6,0">
                            <Label x:Name="HeaderBadgeLabel" Text="3" FontSize="10" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Frame>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNotificationsClicked" />
                        </Grid.GestureRecognizers>
                    </Grid>

                    <BoxView WidthRequest="1" HeightRequest="28" Color="#22304A" Opacity="0.9" />

                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                        <Frame HeightRequest="26" WidthRequest="26" CornerRadius="13" BackgroundColor="#1E293B" HasShadow="False" Padding="0">
                            <Image Source="admin_profile.png" HeightRequest="26" WidthRequest="26" Aspect="AspectFill" />
                        </Frame>
                        <VerticalStackLayout Spacing="0" VerticalOptions="Center">
                            <Label Text="Admin" TextColor="White" FontAttributes="Bold" FontSize="12" />
                            <Label Text="System Administrator" TextColor="#9AA4B2" FontSize="10" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                        <Image Source="logout.png" HeightRequest="16" WidthRequest="16" />
                        <Label Text="Logout" TextColor="White" FontAttributes="Bold" FontSize="12" VerticalOptions="Center" />
                        <HorizontalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLogoutClicked" />
                        </HorizontalStackLayout.GestureRecognizers>
                    </HorizontalStackLayout>
                </HorizontalStackLayout>
            </Grid>

            <!-- Scrollable Content -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="22" Spacing="16">

                    <!-- Page Title -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Settings" FontSize="24" FontAttributes="Bold" TextColor="#0B1220" />
                        <Label Text="Configure system settings and admin preferences" FontSize="13" TextColor="#6B7280" />
                    </VerticalStackLayout>

                    <!-- Admin Profile Card -->
                    <Frame CornerRadius="14" BackgroundColor="White" HasShadow="False" Padding="20" BorderColor="#E5E7EB">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" VerticalOptions="Center">
                            <Frame HeightRequest="64" WidthRequest="64" CornerRadius="32" BackgroundColor="#1E293B" HasShadow="False" Padding="0">
                                <Image Source="admin_profile.png" HeightRequest="64" WidthRequest="64" Aspect="AspectFill" />
                            </Frame>
                            <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                <Label Text="Admin" FontSize="18" FontAttributes="Bold" TextColor="#0B1220" />
                                <Label Text="System Administrator" FontSize="13" TextColor="#6B7280" />
                                <Label Text="admin@agrischolars.ph" FontSize="12" TextColor="#9CA3AF" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" Spacing="8" VerticalOptions="Center">
                                <Frame CornerRadius="8" BackgroundColor="#DCFCE7" HasShadow="False" Padding="10,4">
                                    <Label Text="● Active" TextColor="#16A34A" FontSize="12" FontAttributes="Bold" />
                                </Frame>
                                <Label Text="Last login: Today, 08:14 AM" FontSize="10" TextColor="#9CA3AF" HorizontalOptions="End" />
                            </VerticalStackLayout>
                        </Grid>
                    </Frame>

                    <!-- Two-column layout for settings cards -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16">

                        <!-- LEFT COLUMN -->
                        <VerticalStackLayout Spacing="16">

                            <!-- General Settings -->
                            <Frame CornerRadius="14" BackgroundColor="White" HasShadow="False" Padding="20" BorderColor="#E5E7EB">
                                <VerticalStackLayout Spacing="14">
                                    <HorizontalStackLayout Spacing="10">
                                        <Frame HeightRequest="32" WidthRequest="32" CornerRadius="8" BackgroundColor="#E8F0FF" HasShadow="False" Padding="0">
                                            <Label Text="⚙" HorizontalOptions="Center" VerticalOptions="Center" FontSize="14" />
                                        </Frame>
                                        <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                                            <Label Text="General Settings" FontAttributes="Bold" FontSize="14" TextColor="#0B1220" />
                                            <Label Text="Basic system configuration" FontSize="11" TextColor="#6B7280" />
                                        </VerticalStackLayout>
                                    </HorizontalStackLayout>

                                    <BoxView HeightRequest="1" Color="#F3F4F6" />

                                    <VerticalStackLayout Spacing="10">
                                        <Label Text="Program Name" FontSize="12" TextColor="#374151" FontAttributes="Bold" />
                                        <Frame CornerRadius="10" BackgroundColor="#F9FAFB" HasShadow="False" Padding="12,10" BorderColor="#E5E7EB">
                                            <Entry x:Name="ProgramNameEntry" Text="Agrischolars Program" BackgroundColor="Transparent" TextColor="#0B1220" />
                                        </Frame>

                                        <Label Text="Current Academic Year" FontSize="12" TextColor="#374151" FontAttributes="Bold" />
                                        <Frame CornerRadius="10" BackgroundColor="#F9FAFB" HasShadow="False" Padding="10,8" BorderColor="#E5E7EB">
                                            <Picker x:Name="AcademicYearPicker" BackgroundColor="Transparent" TextColor="#0B1220" Title="Select year">
                                                <Picker.Items>
                                                    <x:String>2025-2026</x:String>
                                                    <x:String>2024-2025</x:String>
                                                    <x:String>2023-2024</x:String>
                                                </Picker.Items>
                                            </Picker>
                                        </Frame>

                                        <Label Text="Current Semester" FontSize="12" TextColor="#374151" FontAttributes="Bold" />
                                        <Frame CornerRadius="10" BackgroundColor="#F9FAFB" HasShadow="False" Padding="10,8" BorderColor="#E5E7EB">
                                            <Picker x:Name="SemesterPicker" BackgroundColor="Transparent" TextColor="#0B1220" Title="Select semester">
                                                <Picker.Items>
                                                    <x:String>First Semester</x:String>
                                                    <x:String>Second Semester</x:String>
                                                    <x:String>Summer</x:String>
                                                </Picker.Items>
                                            </Picker>
                                        </Frame>

                                        <Label Text="Minimum GPA Requirement" FontSize="12" TextColor="#374151" FontAttributes="Bold" />
                                        <Frame CornerRadius="10" BackgroundColor="#F9FAFB" HasShadow="False" Padding="12,10" BorderColor="#E5E7EB">
                                            <Entry x:Name="MinGpaEntry" Text="2.50" BackgroundColor="Transparent" TextColor="#0B1220" Keyboard="Numeric" />
                                        </Frame>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Frame>

                            <!-- Email Settings -->
                            <Frame CornerRadius="14" BackgroundColor="White" HasShadow="False" Padding="20" BorderColor="#E5E7EB">
                                <VerticalStackLayout Spacing="14">
                                    <HorizontalStackLayout Spacing="10">
                                        <Frame HeightRequest="32" WidthRequest="32" CornerRadius="8" BackgroundColor="#DCFCE7" HasShadow="False" Padding="0">
                                            <Label Text="✉" HorizontalOptions="Center" VerticalOptions="Center" FontSize="14" />
                                        </Frame>
                                        <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                                            <Label Text="Email Settings" FontAttributes="Bold" FontSize="14" TextColor="#0B1220" />
                                            <Label Text="Configure system email and notifications" FontSize="11" TextColor="#6B7280" />
                                        </VerticalStackLayout>
                                    </HorizontalStackLayout>

                                    <BoxView HeightRequest="1" Color="#F3F4F6" />

                                    <VerticalStackLayout Spacing="10">
                                        <Label Text="From Email Address" FontSize="12" TextColor="#374151" FontAttributes="Bold" />
                                        <Frame CornerRadius="10" BackgroundColor="#F9FAFB" HasShadow="False" Padding="12,10" BorderColor="#E5E7EB">
                                            <Entry x:Name="FromEmailEntry" Text="noreply@agrischolars.ph" BackgroundColor="Transparent" TextColor="#0B1220" Keyboard="Email" />
                                        </Frame>

                                        <Label Text="Reply-To Email" FontSize="12" TextColor="#374151" FontAttributes="Bold" />
                                        <Frame CornerRadius="10" BackgroundColor="#F9FAFB" HasShadow="False" Padding="12,10" BorderColor="#E5E7EB">
                                            <Entry x:Name="ReplyToEmailEntry" Text="support@agrischolars.ph" BackgroundColor="Transparent" TextColor="#0B1220" Keyboard="Email" />
                                        </Frame>

                                        <Label Text="Admin Contact Number" FontSize="12" TextColor="#374151" FontAttributes="Bold" />
                                        <Frame CornerRadius="10" BackgroundColor="#F9FAFB" HasShadow="False" Padding="12,10" BorderColor="#E5E7EB">
                                            <Entry x:Name="ContactNumberEntry" Text="+63 900 000 0000" BackgroundColor="Transparent" TextColor="#0B1220" Keyboard="Telephone" />
                                        </Frame>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Frame>

                        </VerticalStackLayout>

                        <!-- RIGHT COLUMN -->
                        <VerticalStackLayout Grid.Column="1" Spacing="16">

                            <!-- Notification Settings -->
                            <Frame CornerRadius="14" BackgroundColor="White" HasShadow="False" Padding="20" BorderColor="#E5E7EB">
                                <VerticalStackLayout Spacing="14">
                                    <HorizontalStackLayout Spacing="10">
                                        <Frame HeightRequest="32" WidthRequest="32" CornerRadius="8" BackgroundColor="#FEF3C7" HasShadow="False" Padding="0">
                                            <Label Text="🔔" HorizontalOptions="Center" VerticalOptions="Center" FontSize="14" />
                                        </Frame>
                                        <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                                            <Label Text="Notification Settings" FontAttributes="Bold" FontSize="14" TextColor="#0B1220" />
                                            <Label Text="Manage system alerts and notifications" FontSize="11" TextColor="#6B7280" />
                                        </VerticalStackLayout>
                                    </HorizontalStackLayout>

                                    <BoxView HeightRequest="1" Color="#F3F4F6" />

                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="16">
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="New Application Alerts" FontSize="12" FontAttributes="Bold" TextColor="#0B1220" />
                                            <Label Text="Receive alerts for new scholarship applications" FontSize="11" TextColor="#6B7280" />
                                        </VerticalStackLayout>
                                        <Switch x:Name="NewApplicationSwitch" Grid.Column="1" IsToggled="True" OnColor="#16A34A" />

                                        <VerticalStackLayout Grid.Row="1" Spacing="2">
                                            <Label Text="Document Upload Alerts" FontSize="12" FontAttributes="Bold" TextColor="#0B1220" />
                                            <Label Text="Get notified when scholars upload documents" FontSize="11" TextColor="#6B7280" />
                                        </VerticalStackLayout>
                                        <Switch x:Name="DocumentUploadSwitch" Grid.Row="1" Grid.Column="1" IsToggled="True" OnColor="#16A34A" />

                                        <VerticalStackLayout Grid.Row="2" Spacing="2">
                                            <Label Text="Compliance Warnings" FontSize="12" FontAttributes="Bold" TextColor="#0B1220" />
                                            <Label Text="Alerts for scholars below GPA requirements" FontSize="11" TextColor="#6B7280" />
                                        </VerticalStackLayout>
                                        <Switch x:Name="ComplianceSwitch" Grid.Row="2" Grid.Column="1" IsToggled="True" OnColor="#16A34A" />

                                        <VerticalStackLayout Grid.Row="3" Spacing="2">
                                            <Label Text="Disbursement Alerts" FontSize="12" FontAttributes="Bold" TextColor="#0B1220" />
                                            <Label Text="Get notified of pending disbursement approvals" FontSize="11" TextColor="#6B7280" />
                                        </VerticalStackLayout>
                                        <Switch x:Name="DisbursementSwitch" Grid.Row="3" Grid.Column="1" IsToggled="True" OnColor="#16A34A" />

                                        <VerticalStackLayout Grid.Row="4" Spacing="2">
                                            <Label Text="Email Notifications" FontSize="12" FontAttributes="Bold" TextColor="#0B1220" />
                                            <Label Text="Send alert copies to admin email" FontSize="11" TextColor="#6B7280" />
                                        </VerticalStackLayout>
                                        <Switch x:Name="EmailNotifSwitch" Grid.Row="4" Grid.Column="1" IsToggled="False" OnColor="#16A34A" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Frame>

                            <!-- Security Settings -->
                            <Frame CornerRadius="14" BackgroundColor="White" HasShadow="False" Padding="20" BorderColor="#E5E7EB">
                                <VerticalStackLayout Spacing="14">
                                    <HorizontalStackLayout Spacing="10">
                                        <Frame HeightRequest="32" WidthRequest="32" CornerRadius="8" BackgroundColor="#F3E8FF" HasShadow="False" Padding="0">
                                            <Label Text="🔒" HorizontalOptions="Center" VerticalOptions="Center" FontSize="14" />
                                        </Frame>
                                        <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                                            <Label Text="Security Settings" FontAttributes="Bold" FontSize="14" TextColor="#0B1220" />
                                            <Label Text="Admin access and security controls" FontSize="11" TextColor="#6B7280" />
                                        </VerticalStackLayout>
                                    </HorizontalStackLayout>

                                    <BoxView HeightRequest="1" Color="#F3F4F6" />

                                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="16">
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="Two-Factor Authentication" FontSize="12" FontAttributes="Bold" TextColor="#0B1220" />
                                            <Label Text="Require 2FA for admin login" FontSize="11" TextColor="#6B7280" />
                                        </VerticalStackLayout>
                                        <Switch x:Name="TwoFASwitch" Grid.Column="1" IsToggled="False" OnColor="#16A34A" />

                                        <VerticalStackLayout Grid.Row="1" Spacing="2">
                                            <Label Text="Session Timeout" FontSize="12" FontAttributes="Bold" TextColor="#0B1220" />
                                            <Label Text="Auto-logout after 30 min of inactivity" FontSize="11" TextColor="#6B7280" />
                                        </VerticalStackLayout>
                                        <Switch x:Name="SessionTimeoutSwitch" Grid.Row="1" Grid.Column="1" IsToggled="True" OnColor="#16A34A" />
                                    </Grid>

                                    <!-- Change Password -->
                                    <BoxView HeightRequest="1" Color="#F3F4F6" />
                                    <Label Text="Change Admin Password" FontSize="12" FontAttributes="Bold" TextColor="#374151" />
                                    <Frame CornerRadius="10" BackgroundColor="#F9FAFB" HasShadow="False" Padding="12,10" BorderColor="#E5E7EB">
                                        <Entry x:Name="CurrentPasswordEntry" Placeholder="Current password" IsPassword="True"
                                               BackgroundColor="Transparent" TextColor="#0B1220" PlaceholderColor="#9CA3AF" />
                                    </Frame>
                                    <Frame CornerRadius="10" BackgroundColor="#F9FAFB" HasShadow="False" Padding="12,10" BorderColor="#E5E7EB">
                                        <Entry x:Name="NewPasswordEntry" Placeholder="New password" IsPassword="True"
                                               BackgroundColor="Transparent" TextColor="#0B1220" PlaceholderColor="#9CA3AF" />
                                    </Frame>
                                    <Frame CornerRadius="10" BackgroundColor="#F9FAFB" HasShadow="False" Padding="12,10" BorderColor="#E5E7EB">
                                        <Entry x:Name="ConfirmPasswordEntry" Placeholder="Confirm new password" IsPassword="True"
                                               BackgroundColor="Transparent" TextColor="#0B1220" PlaceholderColor="#9CA3AF" />
                                    </Frame>
                                    <Button Text="Update Password" BackgroundColor="#0B1220" TextColor="White"
                                            CornerRadius="10" Padding="14,10" HorizontalOptions="End"
                                            Clicked="OnChangePasswordClicked" />
                                </VerticalStackLayout>
                            </Frame>

                        </VerticalStackLayout>

                    </Grid>

                    <!-- System Maintenance -->
                    <Frame CornerRadius="14" BackgroundColor="White" HasShadow="False" Padding="20" BorderColor="#E5E7EB">
                        <VerticalStackLayout Spacing="14">
                            <HorizontalStackLayout Spacing="10">
                                <Frame HeightRequest="32" WidthRequest="32" CornerRadius="8" BackgroundColor="#E0F2FE" HasShadow="False" Padding="0">
                                    <Label Text="🛠" HorizontalOptions="Center" VerticalOptions="Center" FontSize="14" />
                                </Frame>
                                <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                                    <Label Text="System Maintenance" FontAttributes="Bold" FontSize="14" TextColor="#0B1220" />
                                    <Label Text="Database operations and data management" FontSize="11" TextColor="#6B7280" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>

                            <BoxView HeightRequest="1" Color="#F3F4F6" />

                            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">

                                <Frame CornerRadius="12" BackgroundColor="#F9FAFB" HasShadow="False" Padding="14" BorderColor="#E5E7EB">
                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="💾" FontSize="22" HorizontalOptions="Center" />
                                        <Label Text="Backup Database" FontSize="12" FontAttributes="Bold" TextColor="#0B1220" HorizontalOptions="Center" />
                                        <Label Text="Export Firestore snapshot" FontSize="10" TextColor="#6B7280" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                                        <Button Text="Run Backup" BackgroundColor="White" TextColor="#0B1220"
                                                BorderColor="#E5E7EB" BorderWidth="1" CornerRadius="8" Padding="10,8"
                                                Clicked="OnBackupDatabaseClicked" />
                                    </VerticalStackLayout>
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer />
                                    </Frame.GestureRecognizers>
                                </Frame>

                                <Frame Grid.Column="1" CornerRadius="12" BackgroundColor="#F9FAFB" HasShadow="False" Padding="14" BorderColor="#E5E7EB">
                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="🗑" FontSize="22" HorizontalOptions="Center" />
                                        <Label Text="Clear Cache" FontSize="12" FontAttributes="Bold" TextColor="#0B1220" HorizontalOptions="Center" />
                                        <Label Text="Remove temporary app data" FontSize="10" TextColor="#6B7280" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                                        <Button Text="Clear Now" BackgroundColor="White" TextColor="#DC2626"
                                                BorderColor="#FCA5A5" BorderWidth="1" CornerRadius="8" Padding="10,8"
                                                Clicked="OnClearCacheClicked" />
                                    </VerticalStackLayout>
                                </Frame>

                                <Frame Grid.Column="2" CornerRadius="12" BackgroundColor="#F9FAFB" HasShadow="False" Padding="14" BorderColor="#E5E7EB">
                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="📤" FontSize="22" HorizontalOptions="Center" />
                                        <Label Text="Export All Data" FontSize="12" FontAttributes="Bold" TextColor="#0B1220" HorizontalOptions="Center" />
                                        <Label Text="Download full data export (CSV)" FontSize="10" TextColor="#6B7280" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                                        <Button Text="Export" BackgroundColor="White" TextColor="#0B1220"
                                                BorderColor="#E5E7EB" BorderWidth="1" CornerRadius="8" Padding="10,8"
                                                Clicked="OnExportDataClicked" />
                                    </VerticalStackLayout>
                                </Frame>

                                <Frame Grid.Column="3" CornerRadius="12" BackgroundColor="#FFF7ED" HasShadow="False" Padding="14" BorderColor="#FED7AA">
                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="⚠" FontSize="22" HorizontalOptions="Center" TextColor="#EA580C" />
                                        <Label Text="Reset Settings" FontSize="12" FontAttributes="Bold" TextColor="#EA580C" HorizontalOptions="Center" />
                                        <Label Text="Restore all settings to defaults" FontSize="10" TextColor="#9A3412" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                                        <Button Text="Reset" BackgroundColor="White" TextColor="#EA580C"
                                                BorderColor="#FED7AA" BorderWidth="1" CornerRadius="8" Padding="10,8"
                                                Clicked="OnResetSettingsClicked" />
                                    </VerticalStackLayout>
                                </Frame>

                            </Grid>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Save Button -->
                    <Grid ColumnDefinitions="*,Auto" Margin="0,4">
                        <Label x:Name="SaveStatusLabel" Text="" TextColor="#16A34A" FontSize="13" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="💾  Save All Settings" BackgroundColor="#16A34A" TextColor="White"
                                CornerRadius="10" Padding="18,12" Clicked="OnSaveAllSettingsClicked" />
                    </Grid>

                </VerticalStackLayout>
            </ScrollView>

            <!-- Notifications Overlay -->
            <Grid x:Name="NotificationsOverlay" Grid.RowSpan="2" IsVisible="False" InputTransparent="False">
                <BoxView BackgroundColor="Transparent">
                    <BoxView.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCloseNotifications" />
                    </BoxView.GestureRecognizers>
                </BoxView>
                <Frame BackgroundColor="#1F2A3A" HasShadow="True" CornerRadius="16" Padding="0" BorderColor="#314055"
                       HorizontalOptions="End" VerticalOptions="Start" Margin="0,64,210,0" WidthRequest="430">
                    <Grid RowDefinitions="Auto,*">

                        <Grid BackgroundColor="#1B2432" Padding="18,14" ColumnDefinitions="Auto,Auto,*,Auto,Auto" ColumnSpacing="12">
                            <Image Source="notification.png" HeightRequest="18" WidthRequest="18" Opacity="0.9" />
                            <Label Grid.Column="1" Text="Notifications" TextColor="White" FontAttributes="Bold" FontSize="16" VerticalOptions="Center" />
                            <Frame x:Name="OverlayBadgeFrame" Grid.Column="2" BackgroundColor="#EF4444" CornerRadius="14" HasShadow="False" Padding="10,4" HorizontalOptions="Start" VerticalOptions="Center">
                                <Label x:Name="OverlayBadgeLabel" Text="3 new" TextColor="White" FontSize="12" FontAttributes="Bold" />
                            </Frame>
                            <HorizontalStackLayout Grid.Column="3" Spacing="8" VerticalOptions="Center" HorizontalOptions="End">
                                <Label Text="✓✓" TextColor="#D5D9E0" FontSize="14" VerticalOptions="Center" />
                                <Label Text="Mark all read" TextColor="#D5D9E0" FontSize="12" FontAttributes="Bold" VerticalOptions="Center" />
                                <HorizontalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnMarkAllReadClicked" />
                                </HorizontalStackLayout.GestureRecognizers>
                            </HorizontalStackLayout>
                            <Label Grid.Column="4" Text="✕" TextColor="#D5D9E0" FontSize="14" VerticalOptions="Center" HorizontalOptions="End">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnCloseNotifications" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>

                        <ScrollView Grid.Row="1" HeightRequest="420">
                            <VerticalStackLayout x:Name="NotificationsList" Spacing="0">
                                <!-- Dynamic notifications will be populated from code-behind -->
                            </VerticalStackLayout>
                        </ScrollView>

                    </Grid>
                </Frame>
            </Grid>

        </Grid>

    </Grid>

</ContentPage>
