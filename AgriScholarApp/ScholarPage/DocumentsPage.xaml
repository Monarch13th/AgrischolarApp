<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AgriScholarApp.ScholarPage.DocumentsPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F6F7FB">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Top App Bar -->
        <Grid Grid.Row="0" BackgroundColor="#0B1220" Padding="20,16" ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto">
            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                <Frame WidthRequest="36" HeightRequest="36" CornerRadius="12" BackgroundColor="#1E293B" HasShadow="False" Padding="0" VerticalOptions="Center">
                    <Label Text="A" FontAttributes="Bold" TextColor="#38BDF8" HorizontalOptions="Center" VerticalOptions="Center" FontSize="16" />
                </Frame>
                <VerticalStackLayout VerticalOptions="Center" Spacing="0">
                    <Label Text="Agrischolars" TextColor="White" FontAttributes="Bold" FontSize="15" />
                    <Label Text="Scholar Portal" TextColor="#94A3B8" FontSize="11" />
                </VerticalStackLayout>
            </HorizontalStackLayout>

            <HorizontalStackLayout Grid.Column="2" Spacing="16" VerticalOptions="Center" HorizontalOptions="End">
                <Label Text="⌕" FontSize="20" TextColor="#94A3B8" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSearchTapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Grid HeightRequest="32" WidthRequest="32">
                    <Frame HeightRequest="32" WidthRequest="32" CornerRadius="16" BackgroundColor="#1E293B" HasShadow="False" Padding="0" InputTransparent="True">
                        <Image Source="notification.png" HeightRequest="16" WidthRequest="16" HorizontalOptions="Center" VerticalOptions="Center" Opacity="0.8" InputTransparent="True" />
                    </Frame>
                    <Frame HeightRequest="18" MinimumWidthRequest="18" CornerRadius="9" BackgroundColor="#EF4444" HasShadow="False" Padding="0" HorizontalOptions="End" VerticalOptions="Start" Margin="0,-4,-4,0" InputTransparent="True">
                        <Label x:Name="NotificationsBadgeLabel" Text="0" FontSize="10" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" InputTransparent="True" />
                    </Frame>
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnNotificationsTapped" />
                    </Grid.GestureRecognizers>
                </Grid>

                <Label Text="☰" FontSize="20" TextColor="#94A3B8" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMenuTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="20">

                <VerticalStackLayout Spacing="4">
                    <Label Text="Documents" FontSize="22" FontAttributes="Bold" TextColor="#0F172A" />
                    <Label Text="Manage and submit required documents" FontSize="13" TextColor="#64748B" />
                </VerticalStackLayout>

                <!-- Segmented tabs -->
                <Frame CornerRadius="20" BackgroundColor="#F1F5F9" HasShadow="False" Padding="4" BorderColor="Transparent">
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                        <Frame x:Name="TabRequired" CornerRadius="16" BackgroundColor="White" HasShadow="False" Padding="12">
                            <Label Text="Action Required" FontSize="13" FontAttributes="Bold" TextColor="#0F172A" HorizontalTextAlignment="Center" />
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTabRequiredTapped" />
                            </Frame.GestureRecognizers>
                        </Frame>

                        <Frame x:Name="TabSubmitted" Grid.Column="1" CornerRadius="16" BackgroundColor="Transparent" HasShadow="False" Padding="12">
                            <Label Text="Submitted" FontSize="13" FontAttributes="Bold" TextColor="#64748B" HorizontalTextAlignment="Center" />
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTabSubmittedTapped" />
                            </Frame.GestureRecognizers>
                        </Frame>
                    </Grid>
                </Frame>

                <!-- Required Submissions Panel -->
                <VerticalStackLayout x:Name="PanelRequired" Spacing="16">
                    <CollectionView ItemsSource="{Binding RequiredItems}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame CornerRadius="20" BackgroundColor="{Binding CardBackground}" BorderColor="{Binding CardBorder}" HasShadow="True" Padding="20" Margin="0,0,0,16">
                                    <VerticalStackLayout Spacing="14">
                                        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="14" RowSpacing="8">
                                            <Frame WidthRequest="36" HeightRequest="36" CornerRadius="18" BackgroundColor="{Binding IconBackground}" HasShadow="False" Padding="0" VerticalOptions="Start">
                                                <Label Text="{Binding IconText}" FontSize="16" TextColor="{Binding IconColor}" HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Frame>

                                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                                <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="15" TextColor="#0F172A" LineBreakMode="TailTruncation" />

                                                <HorizontalStackLayout Spacing="8">
                                                    <Frame CornerRadius="12" BackgroundColor="#EEF2FF" HasShadow="False" Padding="10,4">
                                                        <Label Text="{Binding Category}" FontSize="11" FontAttributes="Bold" TextColor="#4F46E5" />
                                                    </Frame>
                                                    <Frame CornerRadius="12" BackgroundColor="{Binding StatusChipBackground}" HasShadow="False" Padding="10,4">
                                                        <Label Text="{Binding StatusText}" FontSize="11" FontAttributes="Bold" TextColor="{Binding StatusChipTextColor}" />
                                                    </Frame>
                                                </HorizontalStackLayout>

                                                <Label Text="{Binding Description}" FontSize="12" TextColor="#475569" Margin="0,4,0,0" />
                                                <Label Text="{Binding Meta}" FontSize="12" FontAttributes="Bold" TextColor="{Binding MetaColor}" Margin="0,2,0,0" />
                                            </VerticalStackLayout>

                                            <Frame Grid.Column="2" BackgroundColor="#0F172A" CornerRadius="14" Padding="16,10" WidthRequest="110" HeightRequest="44" HasShadow="True" HorizontalOptions="End" VerticalOptions="Center" IsVisible="{Binding ShowUpload}">
                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                                                    <Image Source="upload1.png" HeightRequest="16" WidthRequest="16" VerticalOptions="Center" />
                                                    <Label Grid.Column="1" Text="Upload" TextColor="White" FontSize="13" FontAttributes="Bold" VerticalOptions="Center" />
                                                </Grid>
                                                <Frame.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.UploadRequiredCommand}" CommandParameter="{Binding}" />
                                                </Frame.GestureRecognizers>
                                            </Frame>

                                            <Frame Grid.Column="2" BackgroundColor="#F1F5F9" CornerRadius="14" Padding="16,10" WidthRequest="110" HeightRequest="44" BorderColor="#E2E8F0" HasShadow="False" HorizontalOptions="End" VerticalOptions="Center" IsVisible="{Binding ShowView}">
                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                                                    <Image Source="eye.png" HeightRequest="16" WidthRequest="16" VerticalOptions="Center" />
                                                    <Label Grid.Column="1" Text="View" TextColor="#0F172A" FontSize="13" FontAttributes="Bold" VerticalOptions="Center" />
                                                </Grid>
                                                <Frame.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ViewRequiredCommand}" CommandParameter="{Binding}" />
                                                </Frame.GestureRecognizers>
                                            </Frame>
                                        </Grid>
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Submitted Documents Panel -->
                <VerticalStackLayout x:Name="PanelSubmitted" IsVisible="False" Spacing="16">
                    <Frame CornerRadius="20" BackgroundColor="#F8FAFC" BorderColor="#E2E8F0" HasShadow="False" Padding="20">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Submitted Documents" FontSize="16" FontAttributes="Bold" TextColor="#0F172A" />
                            <Label Text="View, download, and track the status of your records" FontSize="12" TextColor="#64748B" />
                        </VerticalStackLayout>
                    </Frame>

                    <CollectionView ItemsSource="{Binding SubmittedItems}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame CornerRadius="20" BackgroundColor="White" BorderColor="#F1F5F9" HasShadow="True" Padding="16" Margin="0,0,0,16">
                                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="14" RowSpacing="8">
                                        <Frame WidthRequest="36" HeightRequest="36" CornerRadius="18" BackgroundColor="#F1F5F9" HasShadow="False" Padding="0" VerticalOptions="Start">
                                            <Label Text="📄" FontSize="16" TextColor="#0F172A" HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Frame>

                                        <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                            <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="14" TextColor="#0F172A" />
                                            <HorizontalStackLayout Spacing="8">
                                                <Frame CornerRadius="10" BackgroundColor="#EEF2FF" HasShadow="False" Padding="8,4">
                                                    <Label Text="{Binding Category}" FontSize="10" FontAttributes="Bold" TextColor="#4F46E5" />
                                                </Frame>
                                                <Frame CornerRadius="10" BackgroundColor="{Binding StatusChipBackground}" HasShadow="False" Padding="8,4">
                                                    <Label Text="{Binding StatusText}" FontSize="10" FontAttributes="Bold" TextColor="{Binding StatusChipTextColor}" />
                                                </Frame>
                                            </HorizontalStackLayout>
                                            <Label Text="{Binding Meta}" FontSize="11" TextColor="#64748B" Margin="0,2,0,0" />
                                        </VerticalStackLayout>

                                        <HorizontalStackLayout Grid.Column="2" Spacing="8" HorizontalOptions="End" VerticalOptions="Center">
                                            <ImageButton Source="eye.png" BackgroundColor="#F8FAFC" CornerRadius="14" Padding="10,8" WidthRequest="44" HeightRequest="44" Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ViewSubmittedCommand}" CommandParameter="{Binding}" />
                                            <ImageButton Source="download.png" BackgroundColor="#E0E7FF" CornerRadius="14" Padding="10,8" WidthRequest="44" HeightRequest="44" Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DownloadSubmittedCommand}" CommandParameter="{Binding}" />
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
                
                <BoxView HeightRequest="16" Opacity="0" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Navigation -->
        <Grid Grid.Row="2" BackgroundColor="White" Padding="16,12" ColumnDefinitions="*,*,*,*,*" RowDefinitions="Auto">
            <VerticalStackLayout Spacing="6" HorizontalOptions="Center" VerticalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Image Source="home.png" HeightRequest="24" WidthRequest="24" Aspect="AspectFit" Opacity="0.4" />
                <BoxView HeightRequest="4" WidthRequest="24" BackgroundColor="Transparent" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" Spacing="6" HorizontalOptions="Center" VerticalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnRecordsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Image Source="records.png" HeightRequest="24" WidthRequest="24" Aspect="AspectFit" Opacity="0.4" />
                <BoxView HeightRequest="4" WidthRequest="24" BackgroundColor="Transparent" />
            </VerticalStackLayout>

            <Frame Grid.Column="2" WidthRequest="56" HeightRequest="56" CornerRadius="28" BackgroundColor="#3B82F6" HasShadow="True" Padding="0" HorizontalOptions="Center" VerticalOptions="Start" Margin="0,-24,0,0">
                <Image Source="plusicon.png" HeightRequest="24" WidthRequest="24" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnQuickActionTapped" />
                    </Image.GestureRecognizers>
                </Image>
            </Frame>

            <VerticalStackLayout Grid.Column="3" Spacing="6" HorizontalOptions="Center" VerticalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnDocumentsTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Image Source="documents.png" HeightRequest="24" WidthRequest="24" Aspect="AspectFit" />
                <BoxView HeightRequest="4" WidthRequest="24" BackgroundColor="#3B82F6" CornerRadius="2" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="4" Spacing="6" HorizontalOptions="Center" VerticalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnProfileTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Image Source="profile.png" HeightRequest="24" WidthRequest="24" Aspect="AspectFit" Opacity="0.4" />
                <BoxView HeightRequest="4" WidthRequest="24" BackgroundColor="Transparent" />
            </VerticalStackLayout>
        </Grid>

        <!-- Menu Popup -->
        <Grid x:Name="MenuOverlay" Grid.RowSpan="3" IsVisible="False" BackgroundColor="Transparent" InputTransparent="False">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnMenuOverlayTapped" />
            </Grid.GestureRecognizers>

            <Grid HorizontalOptions="End" VerticalOptions="Start" Margin="0,58,14,0" RowDefinitions="10,Auto" WidthRequest="190">
                <Frame Grid.Row="0" WidthRequest="14" HeightRequest="14" CornerRadius="2" BackgroundColor="White" HasShadow="False" Padding="0" Rotation="45" HorizontalOptions="End" Margin="0,0,18,0" />
                <Frame Grid.Row="1" CornerRadius="14" BackgroundColor="White" HasShadow="True" Padding="10" BorderColor="#E5E7EB">
                    <VerticalStackLayout Spacing="8">
                        <Button Text="Logout" Clicked="OnLogoutClicked" BackgroundColor="#F3F4F6" TextColor="#111827" CornerRadius="12" Padding="12,10" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>
        </Grid>

        <Grid x:Name="NotificationsOverlay" Grid.RowSpan="3" IsVisible="False" InputTransparent="False">
            <BoxView BackgroundColor="Transparent">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCloseNotifications" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <Frame BackgroundColor="#1F2A3A" HasShadow="True" CornerRadius="16" Padding="0" BorderColor="#314055" HorizontalOptions="Fill" VerticalOptions="Start" Margin="14,70,14,0">
                <Grid RowDefinitions="Auto,*">

                    <Grid BackgroundColor="#1B2432" Padding="14,12" ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="12">
                        <Image Source="notification.png" HeightRequest="18" WidthRequest="18" Opacity="0.9" />
                        <Label Grid.Column="1" Text="Notifications" TextColor="White" FontAttributes="Bold" FontSize="16" VerticalOptions="Center" />

                        <Frame Grid.Column="2" BackgroundColor="#EF4444" CornerRadius="14" HasShadow="False" Padding="10,4" HorizontalOptions="Start" VerticalOptions="Center" IsVisible="False">
                            <Label Text="2 new" TextColor="White" FontSize="12" FontAttributes="Bold" />
                        </Frame>

                        <Label Grid.Column="3" Text="✕" TextColor="#D5D9E0" FontSize="14" VerticalOptions="Center" HorizontalOptions="End">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCloseNotifications" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <ScrollView Grid.Row="1" HeightRequest="360">
                        <VerticalStackLayout Spacing="0">

                            <Grid x:Name="NotificationRow1" Padding="14,14" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" BackgroundColor="#263548" IsVisible="False">
                                <Frame HeightRequest="36" WidthRequest="36" CornerRadius="18" BackgroundColor="#E9D5FF" HasShadow="False" Padding="0" VerticalOptions="Start">
                                    <Label Text="📄" HorizontalOptions="Center" VerticalOptions="Center" FontSize="16" TextColor="#6D28D9" />
                                </Frame>
                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label x:Name="NotificationTitle1" Text="" TextColor="White" FontAttributes="Bold" FontSize="13" />
                                    <Label x:Name="NotificationBody1" Text="" TextColor="#AAB4C3" FontSize="11" LineBreakMode="WordWrap" />
                                    <Label x:Name="NotificationTime1" Text="" TextColor="#8A94A6" FontSize="10" />
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="🗑" TextColor="#9AA4B2" FontSize="16" VerticalOptions="Center" HorizontalOptions="End">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnDeleteNotification1" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>

                            <BoxView HeightRequest="1" Color="#314055" Opacity="0.75" />

                            <Grid x:Name="NotificationRow2" Padding="14,14" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" BackgroundColor="#263548" IsVisible="False">
                                <Frame HeightRequest="36" WidthRequest="36" CornerRadius="18" BackgroundColor="#DCFCE7" HasShadow="False" Padding="0" VerticalOptions="Start">
                                    <Label Text="✓" HorizontalOptions="Center" VerticalOptions="Center" FontSize="16" TextColor="#15803D" FontAttributes="Bold" />
                                </Frame>
                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label x:Name="NotificationTitle2" Text="" TextColor="White" FontAttributes="Bold" FontSize="13" />
                                    <Label x:Name="NotificationBody2" Text="" TextColor="#AAB4C3" FontSize="11" LineBreakMode="WordWrap" />
                                    <Label x:Name="NotificationTime2" Text="" TextColor="#8A94A6" FontSize="10" />
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="🗑" TextColor="#9AA4B2" FontSize="16" VerticalOptions="Center" HorizontalOptions="End">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnDeleteNotification2" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>

                        </VerticalStackLayout>
                    </ScrollView>

                </Grid>
            </Frame>
        </Grid>

        <!-- Quick Action Bottom Sheet (same as other pages) -->
        <Grid x:Name="QuickActionOverlay" Grid.Row="1" IsVisible="False" BackgroundColor="Transparent" InputTransparent="False">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnQuickActionOverlayTapped" />
            </Grid.GestureRecognizers>

            <Frame VerticalOptions="End" Margin="14,0,14,24" CornerRadius="18" BackgroundColor="White" HasShadow="True" Padding="14">
                <VerticalStackLayout Spacing="10">
                    <Label Text="New Quick Action" FontAttributes="Bold" FontSize="14" TextColor="#111827" HorizontalTextAlignment="Center" />

                    <Frame CornerRadius="14" BackgroundColor="#F9FAFB" HasShadow="False" Padding="12" BorderColor="#E5E7EB">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Frame WidthRequest="28" HeightRequest="28" CornerRadius="8" BackgroundColor="#FEE2E2" HasShadow="False" Padding="0" VerticalOptions="Center">
                                <Label Text="📄" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Frame>
                            <Label Grid.Column="1" Text="Submit Grade Report" FontSize="13" FontAttributes="Bold" TextColor="#111827" VerticalOptions="Center" />
                            <Label Grid.Column="2" Text=">" FontSize="16" TextColor="#9CA3AF" VerticalOptions="Center" />
                        </Grid>
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSubmitGradeReportTapped" />
                        </Frame.GestureRecognizers>
                    </Frame>

                    <Frame CornerRadius="14" BackgroundColor="#F9FAFB" HasShadow="False" Padding="12" BorderColor="#E5E7EB">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Frame WidthRequest="28" HeightRequest="28" CornerRadius="8" BackgroundColor="#DBEAFE" HasShadow="False" Padding="0" VerticalOptions="Center">
                                <Label Text="⬆" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Frame>
                            <Label Grid.Column="1" Text="Upload Document" FontSize="13" FontAttributes="Bold" TextColor="#111827" VerticalOptions="Center" />
                            <Label Grid.Column="2" Text=">" FontSize="16" TextColor="#9CA3AF" VerticalOptions="Center" />
                        </Grid>
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnUploadDocumentTapped" />
                        </Frame.GestureRecognizers>
                    </Frame>

                    <Button Text="Cancel" Clicked="OnQuickActionCancelClicked" BackgroundColor="#F3F4F6" TextColor="#111827" CornerRadius="14" Padding="14" />
                </VerticalStackLayout>
            </Frame>
        </Grid>

    </Grid>
</ContentPage>
