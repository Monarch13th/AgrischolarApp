<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AgriScholarApp.ScholarPage.ScholarLoginPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#EEF8FA">

    <ScrollView>
        <Grid Padding="20" MinimumHeightRequest="720">

            <VerticalStackLayout Spacing="14" VerticalOptions="Center">

                <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                    <Image Source="agrischolar.png" HeightRequest="100" WidthRequest="100" Aspect="AspectFit" Margin="0,0,0,-15"/>
                    <Label Text="Agrischolars Portal" TextColor="#0B1220" FontSize="26" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                    <Label Text="Access your scholarship dashboard" TextColor="#6B7280" FontSize="13" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <Frame CornerRadius="18" BackgroundColor="White" HasShadow="False" Padding="18" BorderColor="#E5E7EB">
                    <VerticalStackLayout Spacing="14">

                        <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                            <Label Text="Welcome Back" TextColor="#0B1220" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                            <Label Text="Sign in to your scholar account" TextColor="#6B7280" FontSize="12" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Email" TextColor="#0B1220" FontSize="12" FontAttributes="Bold" />
                            <Frame CornerRadius="12" BackgroundColor="#F3F4F6" HasShadow="False" Padding="12,6" BorderColor="#E5E7EB">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="1">
                                    <Image Source="icons8_email_24.png" HeightRequest="18" WidthRequest="18" Aspect="AspectFit" VerticalOptions="Center" />
                                    <Entry x:Name="EmailEntry" Grid.Column="1" Placeholder="Enter your email" PlaceholderColor="#9CA3AF" Keyboard="Email" TextColor="#0B1220" BackgroundColor="Transparent" FontSize="14" HeightRequest="40" MinimumHeightRequest="40" Margin="-2,0,0,0" />
                                </Grid>
                            </Frame>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Password" TextColor="#0B1220" FontSize="12" FontAttributes="Bold" />
                            <Frame CornerRadius="12" BackgroundColor="#F3F4F6" HasShadow="False" Padding="12,6" BorderColor="#E5E7EB">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="1">
                                    <Image Source="icons8_password_24.png" HeightRequest="18" WidthRequest="18" Aspect="AspectFit" VerticalOptions="Center" />
                                    <Entry x:Name="PasswordEntry" Grid.Column="1" Placeholder="Enter your password" PlaceholderColor="#9CA3AF" TextColor="#0B1220" BackgroundColor="Transparent" IsPassword="True" FontSize="14" HeightRequest="40" MinimumHeightRequest="40" Margin="-2,0,0,0" />
                                </Grid>
                            </Frame>
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="Auto,*" VerticalOptions="Center">
                            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                <CheckBox x:Name="RememberMeCheckBox" Color="#3B82F6" />
                                <Label Text="Remember me" TextColor="#6B7280" FontSize="12" VerticalOptions="Center" />
                            </HorizontalStackLayout>

                            <Label Grid.Column="1" Text="Forgot password?" TextColor="#3B82F6" FontSize="12" FontAttributes="Bold" HorizontalOptions="End" VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnForgotPasswordClicked" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>

                        <Label x:Name="ErrorLabel" IsVisible="False" TextColor="#DC2626" FontSize="12" />

                        <Button Text="Sign In"
                                Clicked="OnScholarLoginClicked"
                                BackgroundColor="#3B82F6"
                                TextColor="White"
                                CornerRadius="12"
                                Padding="16,14"
                                FontAttributes="Bold" />

                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>

        </Grid>
    </ScrollView>
</ContentPage>
