<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AgriScholarApp.ScholarPage.UploadDocumentPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F6F7FB">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Top App Bar ── -->
        <Grid Grid.Row="0" BackgroundColor="#0B1220" Padding="20,16" ColumnDefinitions="Auto,*" RowDefinitions="Auto">
            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                <Frame WidthRequest="36" HeightRequest="36" CornerRadius="12" BackgroundColor="#1E293B" HasShadow="False" Padding="0" VerticalOptions="Center">
                    <Label Text="A" FontAttributes="Bold" TextColor="#38BDF8" HorizontalOptions="Center" VerticalOptions="Center" FontSize="16" />
                </Frame>
                <VerticalStackLayout VerticalOptions="Center" Spacing="0">
                    <Label Text="Agrischolars" TextColor="White" FontAttributes="Bold" FontSize="15" />
                    <Label Text="Scholar Portal" TextColor="#94A3B8" FontSize="11" />
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </Grid>

        <!-- ── Scrollable Body ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="18,16,18,32" Spacing="16">

                <!-- Section label -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Document Submission" FontSize="22" FontAttributes="Bold" TextColor="#0F172A" />
                    <Label Text="Upload your official documents for scholarship requirements." FontSize="13" TextColor="#64748B" />
                </VerticalStackLayout>

                <!-- ── Document Type Picker Card ── -->
                <Frame CornerRadius="20" BackgroundColor="White" BorderColor="#E2E8F0" HasShadow="False" Padding="0">
                    <VerticalStackLayout Spacing="0">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" Padding="20,16,20,12">
                            <Frame WidthRequest="40" HeightRequest="40" CornerRadius="12"
                                   BackgroundColor="#FEF3C7" HasShadow="False" Padding="0">
                                <Label Text="📁" FontSize="18"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Frame>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="Document Type" FontSize="14" FontAttributes="Bold" TextColor="#0F172A" />
                                <Label Text="Select the category of your document" FontSize="12" TextColor="#64748B" />
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#F1F5F9" />

                        <Frame BorderColor="#CBD5E1" BackgroundColor="Transparent" CornerRadius="12" Padding="0" Margin="16,12,16,16" HasShadow="False">
                            <Picker x:Name="DocumentTypePicker" Title="Select Category..." TextColor="#0F172A" TitleColor="#94A3B8" Margin="8,0" HeightRequest="50">
                                <Picker.Items>
                                    <x:String>COR 1st Sem</x:String>
                                    <x:String>1st Sem Grade</x:String>
                                    <x:String>2nd Sem Grade</x:String>
                                    <x:String>Midterm Exam (1st Sem)</x:String>
                                    <x:String>Midterm Exam Certificate (2nd Sem)</x:String>
                                    <x:String>Other</x:String>
                                </Picker.Items>
                            </Picker>
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

                <!-- ── File Upload Card ── -->
                <Frame CornerRadius="20" BackgroundColor="White" BorderColor="#E2E8F0" HasShadow="False" Padding="0">
                    <VerticalStackLayout Spacing="0">

                        <!-- Card header -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" Padding="20,16,20,12">
                            <Frame WidthRequest="40" HeightRequest="40" CornerRadius="12"
                                   BackgroundColor="#EFF6FF" HasShadow="False" Padding="0">
                                <Label Text="📄" FontSize="18"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Frame>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="Attach File" FontSize="14" FontAttributes="Bold" TextColor="#0F172A" />
                                <Label Text="PDF, JPG, PNG · Max 10 MB" FontSize="12" TextColor="#64748B" />
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#F1F5F9" />

                        <!-- Dashed drop zone -->
                        <Frame Margin="16,16" CornerRadius="16"
                               BackgroundColor="#F8FAFC" BorderColor="#CBD5E1"
                               HasShadow="False" Padding="0" MinimumHeightRequest="150">
                            <VerticalStackLayout Spacing="12" Padding="24,28" HorizontalOptions="Fill" VerticalOptions="Center">
                                <Grid HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label Text="⬆" FontSize="32" TextColor="#3B82F6" HorizontalOptions="Center" VerticalOptions="Center" />
                                    <Image Source="uploaddocs.png" HeightRequest="48" WidthRequest="48" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" Opacity="0.9" />
                                </Grid>
                                <Label Text="Tap to browse files" FontSize="14" FontAttributes="Bold"
                                       TextColor="#1E293B" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                                <Label Text="or drag and drop here" FontSize="12"
                                       TextColor="#94A3B8" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnChooseFileTapped" />
                            </Frame.GestureRecognizers>
                        </Frame>

                        <!-- Selected file badge -->
                        <Frame x:Name="FileInfoFrame" IsVisible="False"
                               Margin="16,0,16,16" CornerRadius="14"
                               BackgroundColor="#F0F9FF" BorderColor="#BAE6FD"
                               HasShadow="False" Padding="14,12">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Frame WidthRequest="36" HeightRequest="36" CornerRadius="10"
                                       BackgroundColor="#DBEAFE" HasShadow="False" Padding="0">
                                    <Label Text="📎" FontSize="16"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Frame>
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label x:Name="SelectedFileLabel" Text="No file selected"
                                           FontSize="13" FontAttributes="Bold" TextColor="#0369A1"
                                           LineBreakMode="TailTruncation" />
                                    <Label x:Name="FileSizeLabel" Text="Tap to change"
                                           FontSize="11" TextColor="#64748B" />
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="✓" FontSize="18"
                                       TextColor="#059669" VerticalOptions="Center" />
                            </Grid>
                        </Frame>

                        <!-- No-file placeholder row -->
                        <Frame x:Name="NoFileFrame"
                               Margin="16,0,16,16" CornerRadius="14"
                               BackgroundColor="#F8FAFC" BorderColor="#E2E8F0"
                               HasShadow="False" Padding="14,12">
                            <Label Text="No file selected" FontSize="13"
                                   TextColor="#94A3B8" HorizontalOptions="Center" />
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

                <!-- ── Notes Card ── -->
                <Frame CornerRadius="20" BackgroundColor="White" BorderColor="#E2E8F0" HasShadow="False" Padding="0">
                    <VerticalStackLayout Spacing="0">

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" Padding="20,16,20,12">
                            <Frame WidthRequest="40" HeightRequest="40" CornerRadius="12"
                                   BackgroundColor="#DCFCE7" HasShadow="False" Padding="0">
                                <Label Text="✏" FontSize="18"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Frame>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="Additional Notes" FontSize="14" FontAttributes="Bold" TextColor="#0F172A" />
                                <Label Text="Optional — context for the reviewer" FontSize="12" TextColor="#64748B" />
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#F1F5F9" />

                        <Editor x:Name="NotesEditor"
                                AutoSize="TextChanges"
                                Placeholder="e.g. This is for the Fall Term requirement."
                                PlaceholderColor="#94A3B8"
                                TextColor="#0F172A"
                                BackgroundColor="White"
                                FontSize="14"
                                HeightRequest="110"
                                Margin="16,12,16,16" />
                    </VerticalStackLayout>
                </Frame>

                <!-- ── Error Banner ── -->
                <Frame x:Name="ErrorFrame" IsVisible="False"
                       CornerRadius="16" BackgroundColor="#FEF2F2" BorderColor="#FECACA"
                       HasShadow="False" Padding="14,12">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Text="⚠" FontSize="16" TextColor="#B91C1C" VerticalOptions="Center" />
                        <Label x:Name="ErrorLabel" Grid.Column="1"
                               Text="" FontSize="13" TextColor="#B91C1C"
                               VerticalOptions="Center" />
                    </Grid>
                </Frame>

                <!-- ── Submit Button ── -->
                <Button x:Name="SubmitButton"
                        Text="Submit Document"
                        Clicked="OnSubmitClicked"
                        BackgroundColor="#3B82F6"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="15"
                        CornerRadius="18"
                        HeightRequest="56"
                        Margin="0,8,0,0" />

                <Button Text="Back"
                        Clicked="OnBackButtonClicked"
                        BackgroundColor="White"
                        TextColor="#0F172A"
                        BorderColor="#E2E8F0"
                        BorderWidth="1"
                        FontAttributes="Bold"
                        FontSize="15"
                        CornerRadius="18"
                        HeightRequest="56"
                        Margin="0,0,0,0" />

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
